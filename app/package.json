{
  "name": "podfire",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "agent-gateway": "node agent-gateway.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run agent-gateway\"",
    "build": "next build",
    "start": "node server.js",
    "lint": "eslint . --max-warnings 0",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma db studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "next": "^16.2.10",
    "octokit": "^3.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-syntax-highlighter": "^16.1.1",
    "ws": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
