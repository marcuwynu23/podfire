generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  email                String?
  githubId             String   @unique
  githubLogin          String?  // GitHub username for display in header
  encryptedAccessToken String?  // AES-256 encrypted GitHub token
  createdAt            DateTime @default(now())
  services             Service[]
  agents               Agent[]
}

model Agent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   // display name; use AGENT_NAME when running the agent process
  createdAt DateTime @default(now())
}

// Keys generated by the agent; user confirms in app (Agents → Confirm key). Gateway accepts WebSocket register only if secret matches one of these.
model AgentRegistrationKey {
  id         String    @id @default(cuid())
  secret     String    @unique // value generated by the agent and pasted in the app
  userId     String
  name       String?   // optional display name for the agent
  lastSeenAt DateTime? // updated on register and heartbeat; used to show offline when stale
  createdAt  DateTime  @default(now())
}

model Service {
  id                     String   @id @default(cuid())
  userId                 String
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                   String
  repoUrl                String
  branch                 String   @default("main")
  framework              String?
  dockerImage            String?
  stackName              String?
  port                   Int?     // container port for Traefik (default: 3000 for Node, 80 for nginx/custom)
  hostPort               Int?     // optional published host port (auto-assigned if null when deploy needs it)
  entryCommand           String?  // e.g. "npm start" or "node server.js"
  buildCommand           String?  // e.g. "npm run build"
  outputDirectory        String?  // e.g. "dist" or ".next" — build output path for Docker COPY
  env                    String?  // JSON object of env vars for the container
  replicas                Int      @default(1) // number of service replicas (Swarm)
  cpuLimit                String?  // optional Docker CPU limit (e.g. "1.5"); applied per replica
  memoryLimit             String?  // optional Docker memory limit (e.g. "512m"); applied per replica
  deployMode             String   @default("manual") // "manual" | "auto" — auto watches branch and deploys on new commits
  lastDeployedCommitSha  String?  // for auto: last commit we deployed (to detect new commits)
  domain                 String?  // optional custom domain from DNS settings (e.g. example.com); empty = use <name>.localhost
  diagnosticsEnabled     Boolean  @default(false) // show Diagnostics tab in app detail (disabled by default)
  createdAt              DateTime @default(now())
  deployments            Deployment[]
}

model Deployment {
  id            String   @id @default(cuid())
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status        String   // queued | building | pushing | deploying | running | failed
  logs          String?
  commitSha     String?  // commit SHA that was deployed (for versioning and auto-deploy compare)
  commitMessage String?  // latest commit message (first line) at time of deploy
  retryCount    Int      @default(0) // number of retries after failure (for retry/backoff)
  phaseDurations String? // JSON: { "clone": 2.1, "build": 45, "push": 12, "deploy": 3 } for structured logs
  agentName     String?  // display name of the agent that ran this deploy (set when job is sent)
  createdAt     DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. cloudflare_api_token, github_client_id
  value    String   // encrypted for secrets; plain for non-secrets like docker_registry URL
  updatedAt DateTime @updatedAt
}
