DATABASE_URL="file:./dev.db"
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/github/callback
ENCRYPTION_KEY=any-secret-passphrase-or-64-char-hex-key
# Leave unset to use local images only (no registry push). Set to e.g. registry.local to push.
# DOCKER_REGISTRY=registry.local
TRAEFIK_NETWORK=web
# Agent gateway (run with: npm run agent-gateway). Used for /api/agents and deploy dispatch.
AGENT_GATEWAY_URL=http://localhost:3001
# Optional: if set, app sends this when calling the gateway HTTP API; gateway rejects HTTP without it. Agent does NOT use this — the agent generates its own key (see Agents → Confirm key).
# GATEWAY_API_SECRET=
# Optional: secret for auto-deploy cron. Call GET /api/cron/auto-deploy?secret=<CRON_SECRET> periodically (e.g. every 5 min).
# CRON_SECRET=your-secret
