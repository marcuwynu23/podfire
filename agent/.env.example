# Agent gateway URL. Run gateway with: cd app && npm run agent-gateway
AGENT_GATEWAY_URL=http://localhost:3001

# Optional: display name when the agent registers (for dashboard listing)
# AGENT_NAME=dockly-agent

# --- No GATEWAY_API_SECRET or any app secret here. The agent is the only one who generates a key. ---
# On first run the agent generates a key, saves it to .agent-key, and prints it.
# Copy that key and confirm it in the app: Dashboard → Agents → Confirm agent key.
# Do not put any secret from the app or gateway in the agent.

# Optional: leave unset for local Docker images only
# DOCKER_REGISTRY=registry.local
